APP_NAME=Transcribation Server
ENVIRONMENT=development
API_KEYS=dev-key

DATABASE_URL=sqlite+aiosqlite:///./app.db
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false

ASR_BACKEND=faster_whisper

# ASR_BACKEND=gigaam
MODEL_NAME=v3_e2e_ctc
LANGUAGE_DEFAULT=ru
PUNCTUATION_DEFAULT=true
ASR_FORCE_MOCK=false
ASR_DEVICE=cuda
GIGAAM_USE_FLASH=false
GIGAAM_DOWNLOAD_ROOT=
FASTER_WHISPER_MODEL=antony66/whisper-large-v3-russian
FASTER_WHISPER_COMPUTE_TYPE=float16
FASTER_WHISPER_BEAM_SIZE=5
FASTER_WHISPER_VAD_FILTER=true
FASTER_WHISPER_TASK=transcribe
FASTER_WHISPER_DOWNLOAD_ROOT=
HF_TOKEN=

MAX_FILE_MB=200
MAX_DURATION_SEC=7200
MAX_QUEUE_SIZE=100
GPU_CONCURRENCY=1

TRANSCODE_ENABLED=true
AUTO_CREATE_TABLES=true
TEMP_DIR=./tmp/audio
CLEANUP_FILES=true

TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PYROGRAM_ENABLED=false
TELEGRAM_PYROGRAM_SESSION_NAME=transcribation_bot
TELEGRAM_AUTH_QUESTION=Введите код доступа
TELEGRAM_AUTH_ANSWER=letmein
TELEGRAM_STATUS_POLL_INTERVAL_SEC=2.0
TELEGRAM_RESULT_WAIT_TIMEOUT_SEC=10800
